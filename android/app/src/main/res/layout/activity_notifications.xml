<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?android:attr/colorBackground">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="所有设备通知" android:textSize="22sp" android:textStyle="bold" android:padding="16dp" />
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/notificationList"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:clipToPadding="false" android:padding="8dp" />
    <TextView android:id="@+id/emptyText" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="暂无通知" android:textSize="16sp"
        android:gravity="center" android:layout_gravity="center" android:visibility="gone" />
</LinearLayout>
